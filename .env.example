# RotaKey v6 — Environment variables
# Copy to .env and fill in your values.
# Never commit .env to git.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your keys
#   docker compose up -d          # docker compose reads .env automatically
#   # or
#   source .env && python3 proxy.py

# ── Inbound authentication ────────────────────────────────────────────────────
# When set, all clients must send:  Authorization: Bearer <value>
# Leave empty to disable (localhost-only use is safe without this)
ROTAKEY_TOKEN=

# ── Port override ─────────────────────────────────────────────────────────────
# ROTAKEY_PORT=8765

# ── API keys ──────────────────────────────────────────────────────────────────
# Preferred over putting keys in rotakey.yaml.
# Comma-separated if you have multiple keys per provider.
#
ROTAKEY_KEYS_OPENROUTER=sk-or-v1-your-key-here,sk-or-v1-second-key-here
ROTAKEY_KEYS_ANTHROPIC=
ROTAKEY_KEYS_OPENAI=
ROTAKEY_KEYS_GEMINI=

# ── Indexed form (alternative — use one or the other, not both) ───────────────
# ROTAKEY_KEY_OPENROUTER_1=sk-or-v1-aaa
# ROTAKEY_KEY_OPENROUTER_2=sk-or-v1-bbb
# ROTAKEY_KEY_ANTHROPIC_1=sk-ant-xxx
